# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (Claude API for brain library)
ANTHROPIC_API_KEY=sk-ant-api03-your-key

# Retell AI (voice agent)
RETELL_API_KEY=key_your-retell-key
RETELL_WEBHOOK_SECRET=key_your-retell-webhook-secret

# Twilio (owner SMS notifications)
TWILIO_ACCOUNT_SID=ACyour-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1your-twilio-number
TWILIO_WEBHOOK_URL=https://your-app.vercel.app/api/webhooks/twilio-sms

# Stripe (billing)
STRIPE_SECRET_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_STANDARD=price_your-standard-price-id
STRIPE_PRICE_PREMIUM=price_your-premium-price-id
STRIPE_PRICE_ENTERPRISE=price_your-enterprise-price-id

# Operator phone (admin SMS alerts)
OPERATOR_PHONE=+1your-operator-phone

# Cron / revalidation secret
CRON_SECRET=your-cron-secret
REVALIDATE_SECRET=your-revalidate-secret
